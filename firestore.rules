rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entities Validation
    function isValidPost(data) {
      return data.keys().hasAll(['userId', 'summary', 'scheduledAt', 'status', 'postType'])
        && data.userId is string
        && data.summary is string && data.summary.size() <= 4096
        && data.scheduledAt is string
        && data.status in ['SCHEDULED', 'PUBLISHED', 'FAILED']
        && data.postType in ['STANDARD', 'EVENT', 'OFFER']
        && (data.imageUrl == null || data.imageUrl is string)
        && (data.accountId == null || data.accountId is string)
        && (data.accountName == null || data.accountName is string)
        && data.userId == request.auth.uid;
    }

    function isValidAccount(data) {
      return data.keys().hasAll(['userId', 'name', 'gmbId'])
        && data.userId == request.auth.uid
        && data.name is string && data.name.size() <= 256
        && data.gmbId is string;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email'])
        && data.uid == request.auth.uid
        && data.email is string;
    }

    // Rules for Posts
    match /posts/{postId} {
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      
      allow create: if isSignedIn() 
        && isValidPost(incoming())
        && (incoming().createdAt == request.time || incoming().createdAt == null);

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && isValidPost(incoming())
        && incoming().userId == existing().userId;

      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for Accounts
    match /accounts/{accountId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidAccount(incoming());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && isValidAccount(incoming());
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Rules for Users
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && isValidUser(incoming());
    }
  }
}
