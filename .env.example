# ─── Supabase (Frontend) ────────────────────────────────────────────────────
# Public anon key — safe to expose in the browser
VITE_SUPABASE_URL=https://bvoszzsyjnrsfntvsiiy.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_0NaRah6DijN1rYtiEqwUKw_9AGPO1Xk

# App URL — used for OAuth redirects (set to your Vercel deployment URL in production)
VITE_APP_URL=http://localhost:3000

# ─── Supabase (Backend / API routes) ────────────────────────────────────────
# Service key — NEVER expose this in the browser. Vercel env only.
SUPABASE_URL=https://bvoszzsyjnrsfntvsiiy.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# ─── Google OAuth (GMB Publishing) ─────────────────────────────────────────
# From Google Cloud Console → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET

# ─── Cron Job Security ──────────────────────────────────────────────────────
# Random secret used to protect /api/publish-posts from unauthorized calls
# Set the same value in cron-job.org request header: x-cron-secret
CRON_SECRET=YOUR_RANDOM_CRON_SECRET

# ─── App URL (Backend) ──────────────────────────────────────────────────────
# Used in serverless API routes for callback URLs (same as VITE_APP_URL)
APP_URL=https://your-app.vercel.app
